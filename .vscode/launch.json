{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Extended GRPO Training",
            "type": "debugpy",
            "request": "launch",
            "module": "deepspeed.launcher.runner", // Use deepspeed launcher as module
            "args": [
                "--num_gpus=1",
                "scripts/run_train_explore_grpo.py",
                "--config-file",
                "./configs/explore_grpo_config.yaml",
                "--infer-host",
                "localhost",
                "--infer-port",
                "30000",
                "--use-infer-server",
                "--infer-cohost-mode",
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceRoot}:${workspaceRoot}/src",
                "NCCL_P2P_DISABLE": "1"
            },
        },
        {
