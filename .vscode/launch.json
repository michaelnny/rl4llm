{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug GRPO Training",
            "type": "debugpy",
            "request": "launch",
            "module": "deepspeed.launcher.runner", // Use deepspeed launcher as module
            "args": [
                "--num_gpus=1",
                "scripts/run_train_grpo.py",
                "--config-file",
                "./configs/grpo_config.yaml"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "HTTP_PROXY": "http://127.0.0.1:1081",
                "HTTPS_PROXY": "http://127.0.0.1:1081",
                "PYTHONPATH": "${workspaceRoot}:${workspaceRoot}/src",
                "NCCL_P2P_DISABLE": "1"
            },
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "HTTP_PROXY": "http://127.0.0.1:1081",
                "HTTPS_PROXY": "http://127.0.0.1:1081",
                "PYTHONPATH": "${workspaceRoot}:${workspaceRoot}/src",
            },
        },
    ]
}